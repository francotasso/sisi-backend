{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "read": {
            "*": "allow",
            "*.env": "deny",
            "*.env.*": "deny",
            "*.env.example": "allow"
        },
        "bash": {
            "*": "allow",
            "cat .env*": "deny",
            "Get-Content *.env*": "deny",
            "type .env*": "deny"
        },
        "edit": {
            "*": "allow",
            "*.env": "deny",
            "*.env.*": "deny"
        }
    }
}